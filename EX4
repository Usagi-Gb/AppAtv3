import React from "react";
import { View, Text, StyleSheet, Pressable, Platform, StatusBar } from "react-native";

export function CustomPressable({ title, onPress }) {
  return (
    <Pressable
      onPress={onPress}
      style={({ pressed }) => [
        styles.btn,
        { opacity: pressed ? 0.7 : 1, transform: [{ scale: pressed ? 0.97 : 1 }] },
      ]}
    >
      <Text style={styles.label}>{title}</Text>
    </Pressable>
  );
}

export default function App() {
  return (
    <View style={styles.container}>
      <CustomPressable title="Pressione" onPress={() => alert("Apertou!")} />
    </View>
  );
}

const styles = StyleSheet.create({
  container: { flex: 1, justifyContent: "center", alignItems: "center", backgroundColor: "#fff", paddingTop: Platform.OS === "android" ? StatusBar.currentHeight : 0 },
  btn: { backgroundColor: "#059669", paddingVertical: 12, paddingHorizontal: 30, borderRadius: 8 },
  label: { color: "white", fontSize: 16, fontWeight: "600" },
});
